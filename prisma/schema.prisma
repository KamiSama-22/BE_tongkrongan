// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  PENGGUNA
}

enum Kebersihan {
  SANGAT_BERSIH
  BERSIH
  STANDAR
  KOTOR
  SANGAT_KOTOR
}

enum MetodeSPK {
  SAW
  WP
  TOPSIS
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  email       String   @unique
  password    String
  address     String?
  role        Role

  tenant      Tenant?
  reviews     Review[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tenant {
  id               Int      @id @default(autoincrement())

  adminId          Int      @unique
  admin            User     @relation(fields: [adminId], references: [id])

  nama             String
  alamat           String
  ratingMaps       Float?
  email            String?
  deskripsi        String?
  jamOperasional   String
  telepon          String?
  mapsUrl          String?
  logo             String?

  kepemilikan      Kepemilikan[]
  menus            Menu[]
  galeris          Galeri[]
  nilaiKategori    TenantNilai[]
  reviews          Review[]
}

model Menu {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  nama        String
  deskripsi   String?
  harga       Decimal
  foto        String?

  tenant      Tenant @relation(fields: [tenantId], references: [id])
}

model Galeri {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  gambar      String
  caption     String?

  tenant      Tenant @relation(fields: [tenantId], references: [id])
}

model Kategori {
  id          Int      @id @default(autoincrement())
  nama        String

  subKategori SubKategori[]
  nilaiTenant TenantNilai[]
}

model SubKategori {
  id          Int      @id @default(autoincrement())
  kategoriId  Int
  nama        String
  nilai       Int
  keterangan  String

  kategori     Kategori @relation(fields: [kategoriId], references: [id])
  tenantNilai  TenantNilai[]
}

model TenantNilai {

  id              Int @id @default(autoincrement())
  tenantId        Int
  kategoriId      Int
  subKategoriId   Int
  nilai           Float

  tenant          Tenant @relation(fields: [tenantId], references: [id])
  kategori        Kategori @relation(fields: [kategoriId], references: [id])
  subKategori     SubKategori @relation(fields: [subKategoriId], references: [id])

}


model Review {

  id              Int @id @default(autoincrement())
  tenantId        Int
  userId          Int
  rating          Float
  kebersihan      Kebersihan
  komentar        String?
  balasan         String?
  createdAt       DateTime @default(now())

  tenant          Tenant @relation(fields: [tenantId], references: [id])
  user            User @relation(fields: [userId], references: [id])

}


model Fasilitas {
  id          Int      @id @default(autoincrement())
  nama        String   @unique
  poin        Int
  createdAt   DateTime @default(now())

  kepemilikan  Kepemilikan[]
}



model Kepemilikan {
  tenantId     Int
  fasilitasId  Int

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fasilitas     Fasilitas  @relation(fields: [fasilitasId], references: [id], onDelete: Cascade)

  @@id([tenantId, fasilitasId])
}